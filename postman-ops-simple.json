            "url": "http://localhost:8080/servicios"
          }
        },
        {
          "name": "POST - crear",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Mantenimiento\",\n  \"precio\": 49.5,\n  \"duracionMinutos\": 60\n}"
            },
            "url": "http://localhost:8080/servicios"
          },
          "event": [
