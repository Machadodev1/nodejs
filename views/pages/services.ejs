<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>

        <h1>Servicios</h1>

        <table class="table table-bordered table-hover">

            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Duración</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                <% servicios.forEach(function(servicio){ %>

                    <tr>

                        <td>
                            <%= servicio.nombre %>
                        </td>
                        <td>
                            <%= servicio.precio %>
                        </td>
                        <td>
                            <%= servicio.duracionMinutos %>
                        </td>

                        <td>

                            <button class="btn btn-outline-info" onclick="verServicio('<%= servicio._id %>')">
                                Ver detalle
                            </button>

                            <a href="#" class="btn btn-outline-warning">Editar</a>

                            <button class="btn btn-outline-danger"
                                onclick="abrirModalEliminarServicio('<%= servicio._id %>')">
                                Eliminar
                            </button>

                        </td>

                    </tr>

                    <% }) %>

            </tbody>

        </table>

    </main>

    <div class="modal fade" id="modalServicio" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Detalle Servicio</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <p><b>Nombre:</b> <span id="nombreServicio"></span></p>
                    <p><b>Precio:</b> <span id="precioServicio"></span></p>
                    <p><b>Duración:</b> <span id="duracionServicio"></span></p>

                </div>

            </div>
        </div>
    </div>

    <div class="modal fade" id="modalEliminarServicio" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Confirmar eliminación</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    ¿Seguro que quieres eliminar este servicio?
                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <form id="formEliminarServicio" method="POST">
                        <button type="button" class="btn btn-danger" onclick="confirmarEliminarServicio()">
                            Eliminar
                        </button>
                    </form>

                </div>

            </div>
        </div>
    </div>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

    <script>

        let servicioId = null;

        async function verServicio(id) {

            const res = await fetch(`/servicios/${id}`);
            const data = await res.json();

            document.getElementById("nombreServicio").textContent = data.nombre;
            document.getElementById("precioServicio").textContent = data.precio;
            document.getElementById("duracionServicio").textContent = data.duracionMinutos;

            new bootstrap.Modal(document.getElementById("modalServicio")).show();

        }

        function abrirModalEliminarServicio(id) {
            servicioId = id;
            new bootstrap.Modal(document.getElementById("modalEliminarServicio")).show();
        }

        function confirmarEliminarServicio() {

            const form = document.getElementById("formEliminarServicio");
            form.action = `/servicios/eliminar/${servicioId}?_method=DELETE`;
            form.submit();

        }

    </script>

</body>

</html>