<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>

        <h1>Productos</h1>

        <table class="table table-bordered table-hover">

            <thead>
                <tr>
                    <th>Stock</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>

                <% productos.forEach(function(producto){ %>

                    <tr>

                        <td>
                            <%= producto.stock %>
                        </td>
                        <td>
                            <%= producto.nombre %>
                        </td>
                        <td>
                            <%= producto.precio %>
                        </td>

                        <td>

                            <button class="btn btn-outline-info" onclick="verProducto('<%= producto._id %>')">
                                Ver detalle
                            </button>

                            <button class="btn btn-outline-warning"
                                onclick="abrirModalEditarProducto('<%= producto._id %>', '<%= producto.nombre %>', '<%= producto.precio %>', '<%= producto.stock %>', '<%= producto.categoria %>')">
                                Editar
                            </button>

                            <button class="btn btn-outline-danger"
                                onclick="abrirModalEliminarProducto('<%= producto._id %>')">
                                Eliminar
                            </button>

                        </td>

                    </tr>

                    <% }) %>

            </tbody>

        </table>

    </main>

    <!-- ================= DETALLE ================= -->

    <div class="modal fade" id="modalProducto" tabindex="-1">

        <div class="modal-dialog modal-lg">

            <div class="modal-content">

                <div class="modal-header">
                    <h5>Detalle Producto</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <p><b>Nombre:</b> <span id="nombreProducto"></span></p>
                    <p><b>Precio:</b> <span id="precioProducto"></span></p>
                    <p><b>Stock:</b> <span id="stockProducto"></span></p>
                    <p><b>Categoría:</b> <span id="categoriaProducto"></span></p>

                </div>

            </div>

        </div>

    </div>

    <!-- ================= EDITAR ================= -->

    <div class="modal fade" id="modalEditarProducto" tabindex="-1">

        <div class="modal-dialog modal-lg">

            <div class="modal-content">

                <div class="modal-header">
                    <h5>Editar Producto</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form id="formEditarProducto" method="POST">

                    <div class="modal-body">

                        <input class="form-control mb-2" id="editNombreProducto" name="nombre" placeholder="Nombre">

                        <input class="form-control mb-2" id="editPrecioProducto" name="precio" placeholder="Precio">

                        <input class="form-control mb-2" id="editStockProducto" name="stock" placeholder="Stock">

                        <input class="form-control mb-2" id="editCategoriaProducto" name="categoria"
                            placeholder="Categoría">

                    </div>

                    <div class="modal-footer">

                        <button class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <button class="btn btn-warning" type="submit">
                            Actualizar
                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <!-- ================= ELIMINAR ================= -->

    <div class="modal fade" id="modalEliminarProducto" tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-header">
                    <h5>Confirmar eliminación</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    ¿Seguro que quieres eliminar este producto?
                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <form id="formEliminarProducto" method="POST">
                        <button type="button" class="btn btn-danger" onclick="confirmarEliminarProducto()">
                            Eliminar
                        </button>
                    </form>

                </div>

            </div>

        </div>

    </div>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

    <script>

        let productoIdEliminar = null;

        async function verProducto(id) {

            const res = await fetch(`/productos/${id}`);
            const data = await res.json();

            document.getElementById("nombreProducto").textContent = data.nombre;
            document.getElementById("precioProducto").textContent = data.precio;
            document.getElementById("stockProducto").textContent = data.stock;
            document.getElementById("categoriaProducto").textContent = data.categoria;

            new bootstrap.Modal(document.getElementById("modalProducto")).show();

        }

        /* ================= EDITAR ================= */

        function abrirModalEditarProducto(id, nombre, precio, stock, categoria) {

            document.getElementById("editNombreProducto").value = nombre;
            document.getElementById("editPrecioProducto").value = precio;
            document.getElementById("editStockProducto").value = stock;
            document.getElementById("editCategoriaProducto").value = categoria;

            document.getElementById("formEditarProducto").action =
                `/productos/editar/${id}?_method=PUT`;

            new bootstrap.Modal(document.getElementById("modalEditarProducto")).show();

        }

        /* ================= ELIMINAR ================= */

        function abrirModalEliminarProducto(id) {
            productoIdEliminar = id;

            new bootstrap.Modal(
                document.getElementById("modalEliminarProducto")
            ).show();

        }

        function confirmarEliminarProducto() {

            const form = document.getElementById("formEliminarProducto");

            form.action = `/productos/eliminar/${productoIdEliminar}?_method=DELETE`;

            form.submit();

        }

    </script>

</body>

</html>