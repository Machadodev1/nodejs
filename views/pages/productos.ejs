<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div>
            <h1>Productos</h1>
            <table id="tabla" class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Stock</th>
                        <th>Nombre</th>
                        <th>Precio</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    <% productos.forEach(function(producto) { %>
                        <tr>
                            <td>
                                <%= producto.stock %>
                            </td>
                            <td>
                                <%= producto.nombre %>
                            </td>
                            <td>
                                <%= producto.precio %>
                            </td>
                            <td>
                                <a href="#" class="btn btn-outline-info">Ver Detalle</a>
                                <a href="#" class="btn btn-outline-warning">Editar</a>
                                <a href="#" class="btn btn-outline-danger">Eliminar</a>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>

</html>